{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/daily-summary", "schedule": "0 11 * * *" },
    { "path": "/api/cleanup-orphans", "schedule": "0 4 * * *" },
    { "path": "/api/cron-gallery-expiry-reminders", "schedule": "0 13 * * *" },
    { "path": "/api/cron-contract-reminders", "schedule": "0 14 * * *" },
    { "path": "/api/cron-payment-reminders", "schedule": "30 14 * * *" },
    { "path": "/api/cron-contract-expiry", "schedule": "0 5 * * *" }
  ]
}
